# ---------------------------------------------------------------------------
# Projeto Sete — variáveis de ambiente (EXEMPLO). Nunca commit valores reais.
# Copie para .env na raiz (api) e para web/.env (VITE_*).
# ---------------------------------------------------------------------------

# --- Supabase (api SERVER-ONLY) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # SERVER ONLY — NUNCA no frontend
SUPABASE_JWT_SECRET=                # api: verificar JWTs de admin

# --- Supabase (web, seguros p/ navegador) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_BASE=/api                  # relativo quando api no mesmo domínio Vercel

# --- Integrações ---
VITE_GOOGLE_MAPS_API_KEY=           # web: embed do Google Maps
GOOGLE_MAPS_API_KEY=                # api: geocoding/validação (opcional)
WHATSAPP_NUMBER=5585998162777       # formato intl p/ wa.me

# Anti-spam do formulário (opcional; honeypot vem por padrão)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=

# --- Envio de e-mail (api) ---
# Opção recomendada: Resend
RESEND_API_KEY=
MAIL_FROM="contato@projetosete.com.br"
ADMIN_NOTIFY_EMAIL=projetosete.gerencia@gmail.com

# Alternativa SMTP (comente Resend se usar SMTP)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# --- App ---
NODE_ENV=development
APP_URL=http://localhost:5173
